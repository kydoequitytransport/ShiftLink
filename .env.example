# .env.example
# Copy to `.env.local` and fill values. Do NOT commit secrets.
# Client-side vars (prefix `NEXT_PUBLIC_`) are safe to expose to the browser.
# Server-side vars (no `NEXT_PUBLIC_`) must be kept secret and set in your host (Vercel, etc.).

# --- Supabase (client) -----------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://zljzkeztczkdamznwpyy.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_yjzTVha-n360aE518xgNJw_KpplVUCa

# If your code expects an anon key name, include it too (client-side):
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# --- Supabase (server-only) -----------------------------------------------
# Keep these out of the repo and set them in your deployment provider
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# --- App / auth settings --------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_a_long_random_string

# Optional third-party keys (server-side)
# STRIPE_SECRET_KEY=sk_test_...
# SENDGRID_API_KEY=SG.xxxxx

# Quick local setup
# 1) Copy to local env file: `cp .env.example .env.local`
# 2) Install and run: `npm install && npm run dev`
